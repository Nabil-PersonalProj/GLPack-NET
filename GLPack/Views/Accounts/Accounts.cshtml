@model GLPack.ViewModels.Companies.DashboardViewModel
@{
    ViewData["Title"] = $"{Model.CompanyName} · Accounts";
    ViewData["Breadcrumb"] = "Companies";
    ViewData["CompanyId"] = Model.CompanyId;
    ViewData["CompanyName"] = Model.CompanyName;
    ViewData["CompanySection"] = "Accounts";
}

<section class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <p class="text-xs uppercase tracking-wide text-gray-400 dark:text-neutral-500">
                Company
            </p>
            <h1 class="text-2xl font-semibold tracking-tight">@Model.CompanyName</h1>
            <p class="text-sm text-gray-500 dark:text-neutral-400">
                List of Accounts
            </p>
        </div>

        <div class="flex items-center gap-2">
            <button id="btnDeleteAccounts"
                    type="button"
                    class="inline-flex items-center rounded-lg border border-red-300 bg-red-50
                           px-3 py-1.5 text-xs font-medium text-red-700
                           hover:bg-red-100 disabled:opacity-40 disabled:cursor-not-allowed">
                Delete selected
            </button>

            <button id="btnImportAccounts"
                    type="button"
                    class="inline-flex items-center rounded-lg border border-gray-300 bg-white px-3 py-1.5
                           text-xs font-medium text-gray-700 hover:bg-gray-50
                           dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-200 dark:hover:bg-neutral-800">
                <i class="fa-solid fa-file-import mr-2"></i>
                Import Accounts
            </button>

            <button id="btnAddAccountRow"
                    type="button"
                    class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium
                           text-white hover:bg-indigo-500">
                <i class="fa-solid fa-plus mr-2"></i>
                New Account
            </button>
        </div>
    </div>

    <!-- Search -->
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div class="relative w-full md:max-w-sm">
            <input id="accountsSearch"
                   class="w-full rounded-lg border border-gray-300 dark:border-neutral-700
                          bg-white dark:bg-neutral-900 px-3 py-2 text-sm
                          focus:outline-none focus:ring-2 focus:ring-indigo-400"
                   type="text"
                   placeholder="Search by code or name..." />
        </div>
    </div>

    <!-- Alerts -->
    <div id="accountsAlertHost"
         class="fixed bottom-4 left-4 z-[60] w-[calc(100vw-2rem)] max-w-xs space-y-2 pointer-events-none lg:bottom-20 lg:left-5 lg:w-52">
    </div>

    <!-- Accounts table -->
    <div class="overflow-x-auto rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-900">
        <table class="min-w-full text-xs">
            <thead class="border-b border-gray-200 dark:border-neutral-800 bg-gray-50 dark:bg-neutral-900/60">
                <tr class="text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                    <th class="px-3 py-2 w-8">
                        <input id="chkAccountsSelectAll"
                               type="checkbox"
                               class="h-4 w-4 rounded border-gray-300 dark:border-neutral-600" />
                    </th>
                    <th class="px-3 py-2 w-32">Code</th>
                    <th class="px-3 py-2">Name</th>
                    <th class="px-3 py-2 w-40">Type</th>
                    <th class="px-3 py-2 w-32 text-right">Actions</th>
                </tr>
            </thead>
            <tbody id="accountsTableBody" class="divide-y divide-gray-100 dark:divide-neutral-800">
                <tr>
                    <td colspan="6" class="px-4 py-4 text-center text-gray-500 dark:text-neutral-400">
                        Loading accounts...
                    </td>
                </tr>
            </tbody>
        </table>
        <div id="accountsPager"
             class="flex items-center justify-between rounded-2xl dark:border-neutral-800 bg-white dark:bg-neutral-900 px-4 py-3 text-sm">
        </div>
    </div>
</section>

<div id="accountImportModal"
     class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4">
    <div class="w-full max-w-lg rounded-lg border border-gray-200 bg-white shadow-xl dark:border-neutral-800 dark:bg-neutral-900">
        <div class="flex items-center justify-between border-b border-gray-200 px-5 py-4 dark:border-neutral-800">
            <div>
                <h2 class="text-sm font-semibold text-gray-900 dark:text-neutral-100">Import Accounts</h2>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">Upload CSV or DBF account list.</p>
            </div>
            <button id="closeAccountImportModal"
                    type="button"
                    class="text-gray-500 hover:text-gray-800 dark:text-neutral-400 dark:hover:text-neutral-100">
                ✕
            </button>
        </div>

        <form id="accountImportForm" class="space-y-4 px-5 py-5">
            <div>
                <label for="accountImportFile"
                       class="mb-1 block text-xs font-medium text-gray-600 dark:text-neutral-300">
                    Account file
                </label>
                <input id="accountImportFile"
                       name="importFile"
                       type="file"
                       accept=".csv,.dbf"
                       class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm
                              file:mr-3 file:rounded-md file:border-0 file:bg-indigo-50 file:px-3 file:py-1.5
                              file:text-xs file:font-medium file:text-indigo-700
                              dark:border-neutral-700 dark:bg-neutral-950 dark:file:bg-indigo-950 dark:file:text-indigo-200" />
            </div>

            <div id="accountImportResult"
                 class="hidden rounded-lg border border-gray-200 bg-gray-50 px-3 py-3 text-xs text-gray-700
                        dark:border-neutral-800 dark:bg-neutral-950 dark:text-neutral-300">
            </div>

            <div class="flex justify-end gap-2 border-t border-gray-200 pt-4 dark:border-neutral-800">
                <button id="cancelAccountImport"
                        type="button"
                        class="rounded-lg border border-gray-300 px-3 py-1.5 text-xs font-medium text-gray-700
                               hover:bg-gray-50 dark:border-neutral-700 dark:text-neutral-200 dark:hover:bg-neutral-800">
                    Cancel
                </button>
                <button id="submitAccountImport"
                        type="submit"
                        class="rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-indigo-500
                               disabled:opacity-50 disabled:cursor-not-allowed">
                    Import
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        window.__page__ = {
            name: "accountsIndex",
            companyId: @Model.CompanyId,
            companyName: "@Model.CompanyName"
        };
    </script>
}
