@model GLPack.ViewModels.Companies.DashboardViewModel
@{
    ViewData["Title"] = $"{Model.CompanyName} · Dashboard";
    ViewData["Breadcrumb"] = "Companies";
    ViewData["CompanyId"] = Model.CompanyId;
    ViewData["CompanyName"] = Model.CompanyName;
    ViewData["CompanySection"] = "Dashboard";
    string importSkippedLinesJson = TempData["ImportSkippedLines"] as string ?? "[]";
}

<section class="space-y-6">

    <!-- Header row -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold tracking-tight">@Model.CompanyName</h1>
        </div>

        <div class="flex items-center gap-2">
            <button type="button"
                    id="openImportModal"
                    class="inline-flex items-center gap-2 rounded-lg border border-gray-200 dark:border-neutral-700
                           px-3 py-1.5 text-xs text-gray-700 dark:text-neutral-100
                           hover:bg-gray-50 dark:hover:bg-neutral-800">
                <span>Import CSV</span>
            </button>
        </div>
    </div>
    @if (TempData["ImportSuccess"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="rounded-xl border border-green-200 dark:border-green-900/50 bg-green-50 dark:bg-green-900/10 p-3 text-xs text-green-800 dark:text-green-200">
            @ok
        </div>
    }
    @if (TempData["ImportError"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="rounded-xl border border-red-200 dark:border-red-900/50 bg-red-50 dark:bg-red-900/10 p-3 text-xs text-red-800 dark:text-red-200">
            Import failed: @err
        </div>
    }

    <!-- Current Errors -->
    <div class="rounded-2xl border border-gray-200 dark:border-neutral-800 p-4">
        <div class="flex items-center justify-between gap-4 mb-3">
            <div>
                <h2 class="text-xs font-semibold text-gray-800 dark:text-neutral-100">
                    Current Errors
                </h2>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">
                    @if (Model.CurrentErrorCount == 0)
                    {
                        <span>No current errors found.</span>
                    }
                    else
                    {
                        <span>@Model.CurrentErrorCount entr@(Model.CurrentErrorCount == 1 ? "y" : "ies") need review.</span>
                    }
                </p>
            </div>

            <a href="/company/@Model.CompanyId/transactions"
               class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">
                Open transactions
            </a>
        </div>

        @if (Model.CurrentErrors.Count > 0)
        {
            <div class="overflow-x-auto -mx-4 -mb-4">
                <table class="min-w-full text-xs">
                    <thead class="border-b border-gray-200 dark:border-neutral-800">
                        <tr class="text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                            <th class="px-4 py-2">Txn No</th>
                            <th class="px-2 py-2">Date</th>
                            <th class="px-2 py-2">Account</th>
                            <th class="px-2 py-2">Issue</th>
                            <th class="px-4 py-2 text-right">Debit</th>
                            <th class="px-4 py-2 text-right">Credit</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                        @foreach (var row in Model.CurrentErrors)
                        {
                            <tr>
                                <td class="px-4 py-2 font-mono text-xs text-gray-600 dark:text-neutral-300">
                                    @row.TransactionNo
                                </td>
                                <td class="px-2 py-2 text-xs text-gray-600 dark:text-neutral-300">
                                    @row.Date.ToString("yyyy-MM-dd")
                                </td>
                                <td class="px-2 py-2 text-xs text-gray-800 dark:text-neutral-100">
                                    <span class="font-mono text-gray-600 dark:text-neutral-300">@row.AccountCode</span>
                                    <span class="text-gray-500 dark:text-neutral-400">·</span>
                                    <span>@row.AccountName</span>
                                </td>
                                <td class="px-2 py-2 text-xs text-red-700 dark:text-red-300">
                                    @row.Issue
                                </td>
                                <td class="px-4 py-2 text-xs text-right text-gray-800 dark:text-neutral-100">
                                    @row.Debit.ToString("N2")
                                </td>
                                <td class="px-4 py-2 text-xs text-right text-gray-800 dark:text-neutral-100">
                                    @row.Credit.ToString("N2")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (Model.CurrentErrorCount > Model.CurrentErrors.Count)
                {
                    <div class="border-t border-gray-200 dark:border-neutral-800 px-4 py-3 text-xs text-gray-500 dark:text-neutral-400">
                        Showing @Model.CurrentErrors.Count of @Model.CurrentErrorCount current errors.
                    </div>
                }
            </div>
        }
    </div>

    <!-- Trial Balance (Homepage) -->
    <div class="rounded-2xl border border-gray-200 dark:border-neutral-800 p-4 lg:col-span-2">
        <div class="flex items-center justify-between mb-2">
            <div>
                <h2 class="text-xs font-semibold text-gray-800 dark:text-neutral-100">
                    Trial Balance
                </h2>
            </div>

            <a href="/company/@Model.CompanyId/reports"
               class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">
                Open full reports
            </a>
        </div>

        <div class="overflow-x-auto -mx-4 -mb-4">
            <table class="min-w-full text-xs">
                <thead class="border-b border-gray-200 dark:border-neutral-800">
                    <tr class="text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                        <th class="px-4 py-2 text-left">Code</th>
                        <th class="px-2 py-2 text-left">Name</th>
                        <th class="px-2 py-2 text-left">Type</th>
                        <th class="px-4 py-2 text-right">Debit</th>
                        <th class="px-4 py-2 text-left">Credit</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                    @if (Model.TrialBalanceRows.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-4 text-xs text-gray-500 dark:text-neutral-400">
                                No trial balance data yet.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in Model.TrialBalanceRows)
                        {
                            <tr data-dashboard-tb-row="1">
                                <td class="px-4 py-1 font-mono text-xs text-gray-600 dark:text-neutral-300">
                                    <a class="hover:underline text-indigo-600 dark:text-indigo-400"
                                       href="/company/@Model.CompanyId/search?accountCode=@row.AccountCode">
                                    @row.AccountCode
                                    </a>
                                </td>
                                <td class="px-2 py-1 text-xs text-gray-800 dark:text-neutral-100">
                                    <a class="hover:underline text-indigo-600 dark:text-indigo-400"
                                       href="/company/@Model.CompanyId/search?accountCode=@row.AccountCode">
                                    @row.AccountName
                                    </a>
                                </td>
                                <td class="px-2 py-1 text-xs text-gray-500 dark:text-neutral-400">
                                    @row.AccountType
                                </td>
                                <td class="px-4 py-1 text-xs text-right text-gray-800 dark:text-neutral-100">
                                    @row.Debit.ToString("N2")
                                </td>
                                <td class="px-4 py-1 text-xs text-left text-gray-800 dark:text-neutral-100">
                                    @row.Credit.ToString("N2")
                                </td>
                            </tr>
                        }

                        <tr class="bg-gray-50 dark:bg-neutral-900/60 font-semibold">
                            <td class="px-4 py-2" colspan="3">Totals</td>
                            <td class="px-4 py-2 text-xs text-right">@Model.TrialBalanceTotalDebit.ToString("N2")</td>
                            <td class="px-4 py-2 text-xs text-left">@Model.TrialBalanceTotalCredit.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (Model.TrialBalanceRows.Count > 0)
            {
                <div id="dashboardTbPager"
                     class="mt-3 flex items-center justify-between rounded-2xl dark:border-neutral-800 bg-transparent dark:bg-transparent px-4 py-3 text-xs">
                </div>
            }
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="rounded-2xl border border-gray-200 dark:border-neutral-800 p-4">
        <div class="flex items-center justify-between gap-4 mb-3">
            <div>
                <h2 class="text-xs font-semibold text-gray-800 dark:text-neutral-100">
                    Recent Transactions
                </h2>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">
                    Latest transactions for this company.
                </p>
            </div>

            <a href="/company/@Model.CompanyId/transactions"
               class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">
                View all
            </a>
        </div>

        <div class="overflow-x-auto -mx-4 -mb-4">
            <table class="min-w-full text-xs">
                <thead class="border-b border-gray-200 dark:border-neutral-800">
                    <tr class="text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                        <th class="px-4 py-2">Txn No</th>
                        <th class="px-2 py-2">Date</th>
                        <th class="px-2 py-2">Description</th>
                        <th class="px-4 py-2 text-right">Debit</th>
                        <th class="px-4 py-2 text-right">Credit</th>
                        <th class="px-4 py-2">Errors</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-neutral-800">
                    @if (Model.RecentTransactions.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-4 text-xs text-gray-500 dark:text-neutral-400">
                                No transactions yet.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in Model.RecentTransactions)
                        {
                            <tr>
                                <td class="px-4 py-2 font-mono text-xs text-gray-600 dark:text-neutral-300">
                                    @row.TransactionNo
                                </td>
                                <td class="px-2 py-2 text-xs text-gray-600 dark:text-neutral-300">
                                    @row.Date.ToString("yyyy-MM-dd")
                                </td>
                                <td class="px-2 py-2 text-xs text-gray-800 dark:text-neutral-100">
                                    @(string.IsNullOrWhiteSpace(row.Description) ? "No description" : row.Description)
                                </td>
                                <td class="px-4 py-2 text-xs text-right text-gray-800 dark:text-neutral-100">
                                    @row.TotalDebit.ToString("N2")
                                </td>
                                <td class="px-4 py-2 text-xs text-right text-gray-800 dark:text-neutral-100">
                                    @row.TotalCredit.ToString("N2")
                                </td>
                                <td class="px-4 py-2 text-xs">
                                    @if (row.HasErrors)
                                    {
                                        <span class="rounded-full bg-red-50 dark:bg-red-900/20 px-2 py-0.5 text-red-700 dark:text-red-300">
                                            Yes
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-500 dark:text-neutral-400">No</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Import Modal -->
<div id="importModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative mx-auto mt-24 w-[92%] max-w-lg rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-950 p-4 shadow-xl">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h3 class="text-xs font-semibold text-gray-800 dark:text-neutral-100">Import CSV</h3>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">
                    Columns must be: DATE, TRXNO, LEDGERNAME, PARTICULAR, DRAMOUNT, CRAMOUNT (in this order).
                </p>
            </div>
            <button type="button" id="closeImportModal" class="text-gray-500 hover:text-gray-800 dark:text-neutral-400 dark:hover:text-neutral-100">✕</button>
        </div>

        <form class="mt-4 space-y-3" method="post" enctype="multipart/form-data" action="/company/@Model.CompanyId/import">
            @Html.AntiForgeryToken()
            <input type="file" name="csvFile" accept=".csv,text/csv" required
                   class="block w-full text-xs text-gray-700 dark:text-neutral-100
                          file:mr-3 file:rounded-lg file:border-0
                          file:bg-gray-100 dark:file:bg-neutral-800 file:px-3 file:py-2
                          file:text-xs file:font-medium file:text-gray-800 dark:file:text-neutral-100" />

            <div class="flex items-center justify-end gap-2">
                <button type="button" id="cancelImport"
                        class="rounded-lg border border-gray-200 dark:border-neutral-800 px-3 py-1.5 text-xs text-gray-700 dark:text-neutral-100 hover:bg-gray-50 dark:hover:bg-neutral-900">
                    Cancel
                </button>
                <button type="submit"
                        class="rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-indigo-500">
                    Import
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Skipped Lines Modal -->
<div id="importSkippedModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50"></div>
    <div class="relative mx-auto mt-24 w-[94%] max-w-3xl rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-950 p-4 shadow-xl">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h3 class="text-xs font-semibold text-gray-800 dark:text-neutral-100">Skipped CSV lines</h3>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">
                    These lines were not imported.
                </p>
            </div>
            <button type="button" id="closeImportSkippedModal" class="text-gray-500 hover:text-gray-800 dark:text-neutral-400 dark:hover:text-neutral-100">✕</button>
        </div>

        <div class="mt-4 max-h-[60vh] overflow-auto rounded-xl border border-gray-200 dark:border-neutral-800">
            <table class="min-w-full text-xs">
                <thead class="border-b border-gray-200 dark:border-neutral-800 bg-gray-50 dark:bg-neutral-900/60">
                    <tr class="text-left font-medium uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                        <th class="px-3 py-2 w-20">Line</th>
                        <th class="px-3 py-2 w-56">Reason</th>
                        <th class="px-3 py-2">Text</th>
                    </tr>
                </thead>
                <tbody id="importSkippedLinesBody" class="divide-y divide-gray-100 dark:divide-neutral-800">
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const importSkippedLines = @Html.Raw(importSkippedLinesJson);

        window.__page__ = {
            name: "companyDashboard",
            companyId: @Model.CompanyId,
            companyName: "@Model.CompanyName"
        };

        const modal = document.getElementById('importModal');
        const openBtn = document.getElementById('openImportModal');
        const closeBtn = document.getElementById('closeImportModal');
        const cancelBtn = document.getElementById('cancelImport');
        const skippedModal = document.getElementById('importSkippedModal');
        const closeSkippedBtn = document.getElementById('closeImportSkippedModal');
        const skippedBody = document.getElementById('importSkippedLinesBody');

        function openModal() { modal.classList.remove('hidden'); }
        function closeModal() { modal.classList.add('hidden'); }
        function closeSkippedModal() { skippedModal?.classList.add('hidden'); }
        function escapeHtml(value) {
            return String(value ?? "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        openBtn?.addEventListener('click', openModal);
        closeBtn?.addEventListener('click', closeModal);
        cancelBtn?.addEventListener('click', closeModal);
        closeSkippedBtn?.addEventListener('click', closeSkippedModal);

        if (Array.isArray(importSkippedLines) && importSkippedLines.length && skippedBody && skippedModal) {
            skippedBody.innerHTML = importSkippedLines.map(line => `
                <tr>
                    <td class="px-3 py-2 font-mono text-gray-600 dark:text-neutral-300">${escapeHtml(line.LineNumber ?? line.lineNumber)}</td>
                    <td class="px-3 py-2 text-red-700 dark:text-red-300">${escapeHtml(line.Reason ?? line.reason)}</td>
                    <td class="px-3 py-2 font-mono text-[11px] text-gray-600 dark:text-neutral-300">${escapeHtml(line.Text ?? line.text)}</td>
                </tr>
            `).join("");
            skippedModal.classList.remove('hidden');
        }

        (function () {
            const rows = Array.from(document.querySelectorAll('[data-dashboard-tb-row="1"]'));
            const host = document.querySelector('#dashboardTbPager');
            const pageSize = 10;

            if (!host) return;

            if (!rows.length) {
                host.innerHTML = "";
                return;
            }

            let page = 1;

            function render() {
                const totalCount = rows.length;
                const totalPages = Math.max(1, Math.ceil(totalCount / pageSize));
                page = Math.min(Math.max(1, page), totalPages);

                const start = (page - 1) * pageSize;
                const end = start + pageSize;

                rows.forEach((row, idx) => {
                    row.classList.toggle('hidden', !(idx >= start && idx < end));
                });

                host.innerHTML = `
                    <div class="text-xs text-gray-500 dark:text-neutral-400">
                        Page ${page} of ${totalPages} · ${totalCount} row(s)
                    </div>
                    <div class="flex items-center gap-2">
                        <button type="button"
                                data-page="prev"
                                class="rounded border border-gray-300 dark:border-neutral-700 px-3 py-1 text-xs ${page <= 1 ? 'opacity-40 cursor-not-allowed' : ''}"
                                ${page <= 1 ? 'disabled' : ''}>
                            Previous
                        </button>
                        <button type="button"
                                data-page="next"
                                class="rounded border border-gray-300 dark:border-neutral-700 px-3 py-1 text-xs ${page >= totalPages ? 'opacity-40 cursor-not-allowed' : ''}"
                                ${page >= totalPages ? 'disabled' : ''}>
                            Next
                        </button>
                    </div>
                `;

                host.querySelector('[data-page="prev"]')?.addEventListener('click', () => {
                    if (page > 1) {
                        page--;
                        render();
                    }
                });

                host.querySelector('[data-page="next"]')?.addEventListener('click', () => {
                    if (page < totalPages) {
                        page++;
                        render();
                    }
                });
            }

            render();
        })();
    </script>
}
