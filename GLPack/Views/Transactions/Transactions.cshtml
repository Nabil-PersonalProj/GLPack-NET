@model GLPack.ViewModels.Companies.DashboardViewModel
@{
    ViewData["Title"] = $"{Model.CompanyName} · Transactions";
    ViewData["Breadcrumb"] = "Companies";
}

<section class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <p class="text-xs uppercase tracking-wide text-gray-400 dark:text-neutral-500">
                Company
            </p>
            <h1 class="text-2xl font-semibold tracking-tight">@Model.CompanyName</h1>
        </div>

        <a href="/company/@Model.CompanyId/dashboard"
           class="inline-flex items-center gap-2 rounded-lg border border-gray-200 dark:border-neutral-700
                  px-3 py-1.5 text-sm text-gray-700 dark:text-neutral-100
                  hover:bg-gray-50 dark:hover:bg-neutral-800">
            <span>← Back to dashboard</span>
        </a>
    </div>

    <!-- Filters + buttons -->
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div class="flex flex-wrap items-center gap-3">
            <div class="relative">
                <input id="txSearch"
                       class="w-56 rounded-lg border border-gray-300 dark:border-neutral-700
                              bg-white dark:bg-neutral-900 px-3 py-2 text-sm
                              focus:outline-none focus:ring-2 focus:ring-indigo-400"
                       type="text"
                       placeholder="Search" />
            </div>
            <!--div id="txExactFilterHost" class="flex items-center gap-2"></!--div> -->
            <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-neutral-400">
                <span>From</span>
                <input id="txFrom"
                       type="date"
                       class="rounded border border-gray-300 dark:border-neutral-700 bg-white dark:bg-neutral-900
                              px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-indigo-400" />
                <span>To</span>
                <input id="txTo"
                       type="date"
                       class="rounded border border-gray-300 dark:border-neutral-700 bg-white dark:bg-neutral-900
                              px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-indigo-400" />
            </div>
        </div>

        <div class="flex items-center gap-2">
            <button id="btnTxDeleteSelected"
                    type="button"
                    class="inline-flex items-center rounded-lg border border-red-300 bg-red-50
                           px-3 py-1.5 text-xs font-medium text-red-700
                           hover:bg-red-100 disabled:opacity-40 disabled:cursor-not-allowed">
                Delete selected
            </button>

            <button id="btnTxNew"
                    type="button"
                    class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium
                           text-white hover:bg-indigo-500">
                <i class="fa-solid fa-plus mr-2"></i>
                New Transaction
            </button>
        </div>
    </div>

    <!-- Alerts -->
    <div id="txAlertHost" class="space-y-2"></div>

    <!-- Detail: header + lines for selected transaction -->
    <div class="space-y-3">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-sm font-semibold text-gray-800 dark:text-neutral-100">
                    Transaction details
                </h2>
                <p id="txCurrentSummary"
                   class="text-xs text-gray-500 dark:text-neutral-400">
                    Select a transaction to view or edit its lines.
                </p>
            </div>
        </div>

        <!-- Header fields (detail panel) -->
        <div class="rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 p-4 space-y-4">
            <div class="grid gap-4 md:grid-cols-4">
                <div>
                    <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1">
                        Txn No
                    </label>
                    <input id="txDetailNo"
                           type="number"
                           class="w-full rounded-lg border border-gray-300 dark:border-neutral-700
                      bg-white dark:bg-neutral-900 px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-indigo-400"
                           placeholder="e.g. 2002"
                           disabled />
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1">
                        Date
                    </label>
                    <input id="txDetailDate"
                           type="date"
                           class="w-full rounded-lg border border-gray-300 dark:border-neutral-700
                      bg-white dark:bg-neutral-900 px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-indigo-400"
                           disabled />
                </div>

                <div class="md:col-span-2">
                    <label class="block text-xs font-medium text-gray-500 dark:text-neutral-400 mb-1">
                        Description
                    </label>
                    <input id="txDetailDescription"
                           type="text"
                           class="w-full rounded-lg border border-gray-300 dark:border-neutral-700
                      bg-white dark:bg-neutral-900 px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-indigo-400"
                           placeholder="Description..."
                           disabled />
                </div>
            </div>
        </div>

        <!-- Lines table -->
        <div class="space-y-2">
            <div class="flex items-center gap-2 justify-end">
                <button id="btnTxEdit"
                        type="button"
                        class="inline-flex items-center rounded-lg border border-gray-200 dark:border-neutral-700
                   px-3 py-1.5 text-xs text-gray-700 dark:text-neutral-100
                   hover:bg-gray-50 dark:hover:bg-neutral-800">
                    <i class="fa-solid fa-pen mr-2"></i>
                    Edit
                </button>

                <button id="btnTxAddLine"
                        type="button"
                        class="inline-flex items-center rounded-lg border border-gray-200 dark:border-neutral-700
                   px-3 py-1.5 text-xs text-gray-700 dark:text-neutral-100
                   hover:bg-gray-50 dark:hover:bg-neutral-800">
                    <i class="fa-solid fa-plus mr-2"></i>
                    Add line
                </button>
            </div>

            <div class="overflow-x-auto rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-900">
                <table class="min-w-full text-sm">
                    <thead class="border-b border-gray-200 dark:border-neutral-800 bg-gray-50 dark:bg-neutral-900/60">
                        <tr class="text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                            <th class="px-4 py-2 w-10">#</th>
                            <th class="px-4 py-2 w-40">Account</th>
                            <th class="px-4 py-2 w-24 text-right">Debit</th>
                            <th class="px-4 py-2 w-24 text-left">Credit</th>
                            <th class="px-4 py-2">Memo</th>
                            <th class="px-4 py-2 w-10 text-right"></th>
                        </tr>
                    </thead>
                    <tbody id="txLinesBody" class="divide-y divide-gray-100 dark:divide-neutral-800">
                        <tr>
                            <td colspan="6" class="px-4 py-4 text-center text-gray-500 dark:text-neutral-400">
                                No transaction selected.
                            </td>
                        </tr>
                    </tbody>
                    <tfoot class="border-t border-gray-200 dark:border-neutral-800 bg-gray-50 dark:bg-neutral-900/60">
                        <tr class="text-xs font-semibold text-gray-700 dark:text-neutral-200">
                            <td colspan="2" class="px-4 py-2 text-right">Total</td>
                            <td id="txTotalDebit" class="px-4 py-2 text-right font-mono">0.00</td>
                            <td id="txTotalCredit" class="px-4 py-2 text-left font-mono">0.00</td>
                            <td colspan="2" class="px-4 py-2"></td>
                        </tr>
                    </tfoot>
                </table>
                <div id="txLinesPager"
                     class="flex items-center justify-between rounded-2xl dark:border-neutral-800 bg-white dark:bg-neutral-900 px-4 py-3 text-sm">
                </div>
            </div>

            <!-- Totals + actions -->
            <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-end">

                <div class="flex items-center gap-2">
                    <button id="btnTxCancel"
                            type="button"
                            class="inline-flex items-center rounded-lg border border-gray-200 dark:border-neutral-700
                                   px-3 py-1.5 text-xs text-gray-700 dark:text-neutral-100
                                   hover:bg-gray-50 dark:hover:bg-neutral-800"
                            disabled>
                        Cancel
                    </button>
                    <button id="btnTxSave"
                            type="button"
                            class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-1.5 text-xs font-medium
                                   text-white hover:bg-indigo-500 disabled:opacity-40 disabled:cursor-not-allowed"
                            disabled>
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Transactions table (master) -->
    <div class="space-y-3">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-sm font-semibold text-gray-800 dark:text-neutral-100">
                    All Transactions
                </h2>
            </div>
        </div>
    
        <div class="overflow-x-auto rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-900">
            <table class="min-w-full text-sm">
                <thead class="border-b border-gray-200 dark:border-neutral-800 bg-gray-50 dark:bg-neutral-900/60">
                    <tr class="text-left text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-neutral-400">
                        <th class="px-3 py-2 w-8">
                            <input id="chkTxSelectAll"
                                   type="checkbox"
                                   class="h-4 w-4 rounded border-gray-300 dark:border-neutral-600" />
                        </th>
                        <th class="px-3 py-2 w-28">Txn No</th>
                        <th class="px-3 py-2 w-28">Date</th>
                        <th class="px-3 py-2">Description</th>
                        <th class="px-3 py-2 w-32 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="txTableBody" class="divide-y divide-gray-100 dark:divide-neutral-800">
                    <tr>
                        <td colspan="6" class="px-4 py-4 text-center text-gray-500 dark:text-neutral-400">
                            Loading transactions...
                        </td>
                    </tr>
                </tbody>
            </table>
            <div id="txMasterPager"
                 class="flex items-center justify-between rounded-2xl dark:border-neutral-800 bg-white dark:bg-neutral-900 px-4 py-3 text-sm">
            </div>
        </div>
    </div>
</section>

<!-- add account modal -->
<div id="txQuickAccountModal"
     class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4">
    <div class="w-full max-w-lg rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-xl">
        <div class="flex items-center justify-between border-b border-gray-200 dark:border-neutral-800 px-5 py-4">
            <div>
                <h3 class="text-sm font-semibold text-gray-900 dark:text-neutral-100">Create account</h3>
                <p class="mt-1 text-xs text-gray-500 dark:text-neutral-400">
                    Add a new account without leaving the transaction page.
                </p>
            </div>

            <button id="btnCloseTxQuickAccountModal"
                    type="button"
                    class="text-gray-500 hover:text-gray-800 dark:text-neutral-400 dark:hover:text-neutral-100">
                ✕
            </button>
        </div>

        <div class="space-y-4 px-5 py-4">
            <div>
                <label for="txQuickAccountName"
                       class="mb-1 block text-xs font-medium text-gray-700 dark:text-neutral-300">
                    Account Name
                </label>
                <input id="txQuickAccountName"
                       type="text"
                       class="w-full rounded-lg border border-gray-300 dark:border-neutral-700 bg-white dark:bg-neutral-950 px-3 py-2 text-sm text-gray-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                       placeholder="e.g. Office Supplies" />
            </div>
            <div>
                <label for="quickAccountPrefix"
                       class="block text-xs font-medium text-gray-700 dark:text-neutral-200 mb-1">
                    Prefix
                </label>

                <select id="quickAccountPrefix"
                        class="w-full rounded-lg border border-gray-300 dark:border-neutral-700
                    bg-white dark:bg-neutral-950 px-3 py-2 text-sm
                    focus:outline-none focus:ring-2 focus:ring-indigo-400">
                    <option value="">Select prefix...</option>
                </select>

                <p id="quickAccountTypePreview"
                       class="mt-1 text-xs text-gray-500 dark:text-neutral-400">
                    Account type comes from selected prefix.
                </p>
            </div>
        </div>

        <div class="flex items-center justify-end gap-2 border-t border-gray-200 dark:border-neutral-800 px-5 py-4">
            <button id="btnCancelTxQuickAccount"
                    type="button"
                    class="inline-flex items-center rounded-lg border border-gray-200 dark:border-neutral-700 px-3 py-2 text-xs text-gray-700 dark:text-neutral-100 hover:bg-gray-50 dark:hover:bg-neutral-800">
                Cancel
            </button>

            <button id="btnSaveTxQuickAccount"
                    type="button"
                    class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-xs font-medium text-white hover:bg-indigo-500">
                Save account
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.__page__ = {
            name: "transactionsIndex",
            companyId: @Model.CompanyId,
            companyName: "@Model.CompanyName"
        };
    </script>
}
