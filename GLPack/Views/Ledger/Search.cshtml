@model GLPack.ViewModels.Companies.DashboardViewModel
@{
    ViewData["Title"] = $"{Model.CompanyName} - Global Search";
    ViewData["Breadcrumb"] = "Companies";
    ViewData["CompanyId"] = Model.CompanyId;
    ViewData["CompanyName"] = Model.CompanyName;
    ViewData["CompanySection"] = "Search";
}

<section class="space-y-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl font-semibold tracking-tight">Global Search</h1>
                <p class="text-xs text-gray-500 dark:text-neutral-400 mt-1">
                    Company: <span class="font-medium text-gray-700 dark:text-neutral-200">@Model.CompanyName</span>
                </p>
            </div>
        </div>

        <div class="rounded-2xl border border-gray-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-sm">
            <div class="p-4">
                
                <div class="mb-3">
                    <label class="mb-1 ml-1 block text-sm font-medium text-gray-700 dark:text-neutral-200" for="ledgerSearchInput">Search</label>
                        <div class="flex items-center gap-2">
                            <input id="ledgerSearchInput"
                                   type="text"
                                   placeholder="Search accounts, transaction no, memo, description..."
                                   class="w-full flex-1 rounded-md border border-gray-300 dark:border-neutral-700
                                    bg-white dark:bg-neutral-900 px-3 py-2 text-xs
                                    text-gray-900 dark:text-neutral-100
                                    placeholder:text-gray-400 dark:placeholder:text-neutral-500
                                    focus:outline-none focus:ring-2 focus:ring-indigo-400"
                                   autocomplete="off" />

                            <button id="btnLedgerSearch"
                                    class="shrink-0 inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-xs font-medium text-white hover:bg-indigo-500">
                                Search
                            </button>

                            <button id="btnLedgerClear"
                                    class="shrink-0 inline-flex items-center rounded-md border border-gray-200 dark:border-neutral-700
                                        bg-white dark:bg-neutral-900 px-4 py-2 text-xs font-medium
                                        text-gray-700 dark:text-neutral-100
                                        hover:bg-gray-50 dark:hover:bg-neutral-800">
                                Clear
                            </button>
                        </div>
                    </div>
                

                <div id="ledgerAlertHost" class="mt-4"></div>
            </div>

            <div class="border-t border-gray-200 dark:border-neutral-800">
                <div class="overflow-hidden rounded-b-2xl">
                    <table class="min-w-full text-xs">
                        <thead class="bg-gray-50 dark:bg-neutral-900/60">
                            <tr class="border-b border-gray-200 dark:border-neutral-800">
                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-neutral-400">Transaction No.</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-gray-500 dark:text-neutral-400">Date</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-gray-500 dark:text-neutral-400">Account No.</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-gray-500 dark:text-neutral-400">Description</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-gray-500 dark:text-neutral-400">Memo</th>
                                <th class="px-4 py-3 text-right text-xs font-semibold uppercase text-gray-500 dark:text-neutral-400">Debit</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-gray-500 dark:text-neutral-400">Credit</th>
                            </tr>
                        </thead>

                        <tbody id="ledgerResultsBody" class="divide-y divide-gray-100 dark:divide-neutral-800 bg-white dark:bg-neutral-900">
                            <tr>
                                <td class="px-4 py-4 text-xs text-gray-500 dark:text-neutral-400" colspan="7">
                                    Start typing a query, or arrive here via an Account/Transaction link.
                                </td>
                            </tr>
                        </tbody>
                        <tfoot id="ledgerTotalsBody" class="bg-gray-50 dark:bg-neutral-900/80 border-t border-gray-200 dark:border-neutral-800">
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
</section>


@section Scripts {
    <script>
        window.__page__ = {
            name: "ledgerSearch",
            companyId: @Model.CompanyId
        };
    </script>
}
